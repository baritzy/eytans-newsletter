---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import fs from "node:fs";
import path from "node:path";

// Load monthly cost from costs.json
let monthlyCost = 0;
try {
  const costsPath = path.resolve("../data/costs.json");
  if (fs.existsSync(costsPath)) {
    const data = JSON.parse(fs.readFileSync(costsPath, "utf-8"));
    const monthKey = new Date().toISOString().slice(0, 7);
    monthlyCost = (data.monthly && data.monthly[monthKey]) || 0;
  }
} catch (e) {
  console.warn("could not read costs.json:", e);
}

const postsRaw = await getCollection("posts");
postsRaw.sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));

const categories = ["כל הקטגוריות", "Tesla", "Palantir", "AI", "Markets", "Innovation", "General"];

function fmtDate(d) {
  const dt = new Date(d);
  return dt.toLocaleDateString("he-IL", { day: "numeric", month: "long" });
}

function fmtDateISO(d) {
  return new Date(d).toISOString().slice(0, 10);
}

function fmtDuration(secs) {
  if (!secs) return "";
  const m = Math.round(secs / 60);
  return m + " דק׳";
}

function getErrorMessage(errorCode) {
  const map = {
    segments_not_loaded: "הכתוביות לא נטענו בזמן, ננסה מחר",
    no_transcript: "לוידאו הזה אין כתוביות ביוטיוב",
    members_only: "הוידאו למנויים בלבד",
  };
  return map[errorCode] || "שגיאה טכנית, ננסה מחר";
}

function getExcerpt(body) {
  const clean = body
    .replace(/^#{1,6}\s+.+$/gm, "")
    .replace(/^[\-\*]\s+/gm, "")
    .replace(/\n+/g, " ")
    .trim();
  if (clean.length <= 150) return clean;
  return clean.slice(0, 150).trimEnd() + "...";
}
---
<Base monthlyCost={monthlyCost}>
  <div class="filter-pills" id="filter-pills">
    {categories.map((c, i) => (
      <button class="pill" data-active={i === 0 ? "true" : "false"} data-cat={c === "כל הקטגוריות" ? "all" : c}>{c}</button>
    ))}
  </div>

  {postsRaw.length === 0 ? (
    <div class="empty-state">עדיין אין פוסטים. הגיע אחרי הריצה היומית הראשונה.</div>
  ) : (
    <div id="posts-list">
      {postsRaw.map((p) => {
        const isError = p.data.status === "error";
        const excerpt = isError ? "" : getExcerpt(p.body ?? "");
        const errorMsg = isError ? getErrorMessage((p.data as any).error ?? "") : "";
        return (
          <article class="post" data-cat={p.data.category} data-vid={p.data.video_id}>
            <div class="post-eyebrow">{p.data.category}</div>
            <h2 class="post-title">{p.data.hebrew_title}</h2>
            <div class="post-meta">
              <span class="channel">{p.data.channel}</span>
              <span class="dot">·</span>
              <time datetime={fmtDateISO(p.data.date)}>{fmtDate(p.data.date)}</time>
              {p.data.duration_sec ? (
                <>
                  <span class="dot">·</span>
                  <span>{fmtDuration(p.data.duration_sec)}</span>
                </>
              ) : null}
            </div>

            {isError ? (
              <p class="error-message">{errorMsg}</p>
            ) : (
              <>
                <p class="post-excerpt">{excerpt}</p>
                <div class="post-body">
                  <div class="post-summary" set:html={p.rendered?.html ?? ""} />
                </div>
                <div class="post-actions">
                  <button class="toggle-btn" aria-expanded="false">קרא עוד ▾</button>
                  <a class="source-link" href={p.data.video_url} target="_blank" rel="noopener">צפה במקור ←</a>
                </div>
              </>
            )}
            <button class="read-btn">✓ נקרא</button>
          </article>
        );
      })}
    </div>
  )}

  <script is:inline>
    (function () {
      // Category filter
      const pills = document.querySelectorAll("#filter-pills .pill");
      const posts = document.querySelectorAll("#posts-list .post");
      pills.forEach(function(pill) {
        pill.addEventListener("click", function() {
          var cat = pill.dataset.cat;
          pills.forEach(function(p) { p.setAttribute("data-active", "false"); });
          pill.setAttribute("data-active", "true");
          posts.forEach(function(post) {
            post.style.display = (cat === "all" || post.dataset.cat === cat) ? "" : "none";
          });
        });
      });

      // Expand / collapse cards
      posts.forEach(function(post) {
        var title = post.querySelector(".post-title");
        var toggleBtn = post.querySelector(".toggle-btn");
        var body = post.querySelector(".post-body");
        var sourceLink = post.querySelector(".source-link");

        if (!toggleBtn || !body) return;

        function expand() {
          body.classList.add("is-open");
          toggleBtn.textContent = "סגור ▴";
          toggleBtn.setAttribute("aria-expanded", "true");
          if (sourceLink) sourceLink.classList.add("visible");
        }

        function collapse() {
          body.classList.remove("is-open");
          toggleBtn.textContent = "קרא עוד ▾";
          toggleBtn.setAttribute("aria-expanded", "false");
          if (sourceLink) sourceLink.classList.remove("visible");
        }

        function toggle() {
          if (body.classList.contains("is-open")) {
            collapse();
          } else {
            expand();
          }
        }

        if (title) title.addEventListener("click", toggle);
        toggleBtn.addEventListener("click", toggle);
      });

      // Read / unread tracking via localStorage
      var READ_KEY = "newsletter-read";
      function getReadSet() {
        try { return new Set(JSON.parse(localStorage.getItem(READ_KEY) || "[]")); }
        catch (e) { return new Set(); }
      }
      function saveReadSet(s) {
        localStorage.setItem(READ_KEY, JSON.stringify(Array.from(s)));
      }

      var readSet = getReadSet();

      posts.forEach(function(post) {
        var vid = post.dataset.vid;
        var btn = post.querySelector(".read-btn");
        if (!vid || !btn) return;

        if (readSet.has(vid)) {
          post.classList.add("is-read");
          btn.textContent = "↩ בטל סימון";
        }

        btn.addEventListener("click", function(e) {
          e.stopPropagation();
          if (readSet.has(vid)) {
            readSet.delete(vid);
            post.classList.remove("is-read");
            btn.textContent = "✓ נקרא";
          } else {
            readSet.add(vid);
            post.classList.add("is-read");
            btn.textContent = "↩ בטל סימון";
          }
          saveReadSet(readSet);
        });
      });
    })();
  </script>
</Base>
